        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "from sklearn.preprocessing import MinMaxScaler, StandardScaler\n",
        "\n",
        "\n",
        "print(\"_____Task 1 — Clean the Data_____\")\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    'customer_id': [1, 2, 3, 4, 2, 5],\n",
        "    'age':         [25, np.nan, 35, np.nan, np.nan, 40],\n",
        "    'city':        ['Mumbai', 'Delhi', np.nan, 'Mumbai', 'Delhi', np.nan],\n",
        "    'gender':      ['Male', 'Female', 'Female', 'Male', 'Female', 'Male'],\n",
        "    'annual_income': [40000, 80000, 60000, 120000, 80000, 95000]\n",
        "})\n",
        "\n",
        "df['age'] = df['age'].fillna(df['age'].median())\n",
        "print(\"Imputed missing values in age with the median\")\n",
        "\n",
        "df['city'] = df['city'].fillna(df['city'].mode()[0])\n",
        "print(\"Imputed missing values in city with the mode\")\n",
        "\n",
        "df.drop_duplicates(inplace=True)\n",
        "print(df.duplicated())\n",
        "print(\"Removed duplicate rows\")\n",
        "print(df.info())\n",
        "\n",
        "print(\"_____Task 2 — Encode Categorical Columns_____\")\n",
        "\n",
        "df = pd.get_dummies(df, columns=['city'], drop_first=True, dtype=int)\n",
        "print(\"Applied One-Hot Encoding to 'city'\")\n",
        "\n",
        "le = LabelEncoder()\n",
        "df['gender_encoded'] = le.fit_transform(df['gender'])\n",
        "df.drop('gender', axis=1, inplace=True)\n",
        "print(\"# Applied Label Encoding to 'gender'\")\n",
        "\n",
        "print(df.head())\n",
        "\n",
        "print(\"_____Task 3 — Scale Numerical Features_____\")\n",
        "\n",
        "# Identify numerical columns for scaling\n",
        "numerical_cols = ['age', 'annual_income']\n",
        "\n",
        "# Make copies of the DataFrame to apply different scalers independently\n",
        "df_minmax = df.copy()\n",
        "df_standard = df.copy()\n",
        "\n",
        "# Min-Max Scaling\n",
        "minmax_scaler = MinMaxScaler()\n",
        "df_minmax[numerical_cols] = minmax_scaler.fit_transform(df_minmax[numerical_cols])\n",
        "print(\"\\nDataFrame after Min-Max Scaling:\")\n",
        "print(df_minmax.head())\n",
        "\n",
        "# Standardisation\n",
        "standard_scaler = StandardScaler()\n",
        "df_standard[numerical_cols] = standard_scaler.fit_transform(df_standard[numerical_cols])\n",
        "print(\"\\nDataFrame after Standardisation:\")\n",
        "print(df_standard.head())\n",
        "\n"
      ]
